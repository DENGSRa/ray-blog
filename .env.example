# Your public domain. Its A/AAAA DNS record must already point to this Armbian device.
DOMAIN=blog.example.com

# Used by Let's Encrypt to notify you about certificate renewal problems.
ACME_EMAIL=you@example.com

# Browser-level login for /admin and all content-changing API requests.
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-to-a-long-random-password
# Generate this with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-strong-password'
ADMIN_PASSWORD_HASH=$2a$14$replace-this-with-a-real-caddy-bcrypt-hash

# 图片上传设置（可选）
# 原图上传上限；处理后会自动转成 WebP。
MAX_UPLOAD_SIZE_MB=12
# 输出图片最长边，适合手机照片与博客展示。
IMAGE_MAX_DIMENSION=2400
# WebP 质量，范围 1-100。
IMAGE_WEBP_QUALITY=84
